# MCP Data Science Assistant - Environment Variables

# Used by the MCP tool query_google_gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Used by the custom terminal chat client
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional server name shown to MCP hosts
MCP_SERVER_NAME=MCP-Powered Data Science Assistant

# Optional explicit project root. Set this when an MCP host launches the package
# outside the repository directory and you still want relative paths like data/ to work.
MCP_PROJECT_ROOT=

# Directory where CSV/TSV files are allowed to be read from.
# Relative paths resolve from MCP_PROJECT_ROOT when set, otherwise from the repo root.
ALLOWED_DATA_DIR=data

# Directory where generated plots are saved
OUTPUT_DIR=outputs/generated_plots

# Maximum CSV/TSV file size in MB
MAX_CSV_SIZE_MB=50

# Logging level and optional rotating log file
LOG_LEVEL=INFO
LOG_FILE=
